# =============================================================
# Configuration du systeme RAG agentique Formule 1
# Copier ce fichier en `.env` puis renseigner UNE des cles.
# =============================================================

# Fournisseur LLM : groq | google | ollama
LLM_PROVIDER=groq

# --- Option 1 : Groq (gratuit) -> https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Option 2 : Google Gemini (gratuit) -> https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# --- Option 3 : Ollama (local, aucune cle) -> https://ollama.com
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Modele d'embeddings (local, gratuit, multilingue FR/EN, via ONNX) ---
# Alternatives supportees, par qualite croissante et vitesse decroissante :
#   sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2   (0.22 Go, 384d) <- defaut
#   sentence-transformers/paraphrase-multilingual-mpnet-base-v2   (1.0 Go,  768d)
#   intfloat/multilingual-e5-large                                (2.24 Go, 1024d)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Parametres de generation ---
LLM_TEMPERATURE=0.0
JUDGE_TEMPERATURE=0.0
